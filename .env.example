PAPER2LAB_APP_NAME=Paper2Lab
PAPER2LAB_ENV=development
PAPER2LAB_API_PREFIX=/api
PAPER2LAB_CORS_ORIGINS=http://localhost:5173
PAPER2LAB_DATABASE_URL=sqlite:///./backend/data/paper2lab.db
PAPER2LAB_LOG_LEVEL=INFO
PAPER2LAB_ENABLE_ONLINE_SOURCES=false
PAPER2LAB_ARXIV_API_URL=http://export.arxiv.org/api/query
PAPER2LAB_OPENAI_BASE_URL=https://api.openai.com/v1
PAPER2LAB_OPENAI_API_KEY=
PAPER2LAB_OPENAI_MODEL=gpt-4.1-mini
PAPER2LAB_DEFAULT_TIMEZONE=Asia/Shanghai
PAPER2LAB_SCHEDULER_ENABLED=true

